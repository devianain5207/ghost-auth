{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$core/*": ["./src/core/*"],
      "$shared/*": ["../shared/*"],
      "$locales/*": ["../src/lib/i18n/locales/*"]
    },
    "types": ["chrome"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.svelte", "../shared/**/*.ts", "../shared/**/*.svelte"]
}
